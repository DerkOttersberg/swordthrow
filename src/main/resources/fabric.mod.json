{
	"schemaVersion": 1,
	"id": "swordthrow",
	"version": "${version}",
	"name": "Sword Throw",
	"description": "Throw your currently held sword with R using a heavy curved projectile arc and first-person throw pose animation.",
	"authors": [
		"derko"
	],
	"contact": {
		"sources": "https://github.com/derko/swordthrow"
	},
	"license": "MIT",
	"icon": "assets/swordthrow/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.derko.swordthrow.SwordThrowMod"
		],
		"client": [
			"com.derko.swordthrow.client.SwordThrowClient"
		]
	},
	"mixins": [
		{
			"config": "swordthrow.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.2",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
		"another-mod": "*"
	}
}